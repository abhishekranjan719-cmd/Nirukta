# ============================================================================
# Environment Mode
# ============================================================================
# MODE can be: local (development with hot reload) or dev (Docker production-like)
MODE=local

# ============================================================================
# Backend Configuration
# ============================================================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_ENGINE_URL=http://localhost:8001
BACKEND_ENGINE_TIMEOUT=30
BACKEND_LOG_LEVEL=info
BACKEND_CORS_ORIGINS=["http://localhost:5173"]
BACKEND_RELOAD=true

# ============================================================================
# Engine Configuration
# ============================================================================
ENGINE_HOST=0.0.0.0
ENGINE_PORT=8001
# IMPORTANT: Engine should only accept requests from Backend
ENGINE_CORS_ORIGINS=["http://localhost:8000"]
ENGINE_RELOAD=true

# ============================================================================
# Frontend Configuration (loaded by Vite at build time)
# ============================================================================
VITE_BACKEND_URL=http://localhost:8000

# ============================================================================
# PostgreSQL (Consolidated) - Single instance for all services
# ============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD
POSTGRES_DB=postgres

# Database 1: Backend/Engine
MAIN_DB_NAME=main_db
MAIN_DB_USER=main_user
MAIN_DB_PASSWORD=CHANGE_ME_MAIN_PASSWORD

# Database 2: Langfuse
LANGFUSE_DB_NAME=langfuse
LANGFUSE_DB_USER=langfuse
LANGFUSE_DB_PASSWORD=CHANGE_ME_LANGFUSE_PASSWORD

# Database 3: LiteLLM
LITELLM_DB_NAME=litellm
LITELLM_DB_USER=litellm
LITELLM_DB_PASSWORD=CHANGE_ME_LITELLM_PASSWORD

# Database 4: LangGraph (Agent Memory & Checkpointing)
LANGGRAPH_DB_NAME=langgraph
LANGGRAPH_DB_USER=langgraph
LANGGRAPH_DB_PASSWORD=CHANGE_ME_LANGGRAPH_PASSWORD

# LangGraph Memory Configuration
LANGGRAPH_MEMORY_ENABLED=true
LANGGRAPH_MESSAGE_TRIM_ENABLED=true
LANGGRAPH_MESSAGE_TRIM_KEEP_LAST=5
LANGGRAPH_MESSAGE_TRIM_MAX_TOKENS=4000

# ============================================================================
# Redis (Consolidated) - Single instance with multiple databases
# ============================================================================
# DB 0: Backend/Engine (cache, vector, pub/sub)
# DB 1: Langfuse (queue, cache)
# DB 2: LiteLLM (response cache)
REDIS_PASSWORD=
REDIS_MAX_MEMORY=1024mb

# ============================================================================
# Microsoft SQL Server
# ============================================================================
MSSQL_SA_PASSWORD=CHANGE_ME_SQLSERVER_PASSWORD

# ============================================================================
# ClickHouse (Analytics for Langfuse v3)
# ============================================================================
CLICKHOUSE_PASSWORD=CHANGE_ME_CLICKHOUSE_PASSWORD

# ============================================================================
# MinIO (S3-compatible storage for Langfuse v3)
# ============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD

# ============================================================================
# Langfuse (LLM Observability Platform)
# ============================================================================
# Enable/Disable Langfuse tracing (set to false to disable all tracing)
LANGFUSE_ENABLED=true

# Core Configuration - IMPORTANT: Generate random 32-character strings for production
# Use: openssl rand -hex 32
LANGFUSE_NEXTAUTH_SECRET=CHANGE_ME_GENERATE_RANDOM_32_CHAR_HEX
LANGFUSE_ENCRYPTION_KEY=CHANGE_ME_GENERATE_RANDOM_32_CHAR_HEX
LANGFUSE_SALT=CHANGE_ME_GENERATE_RANDOM_32_CHAR_HEX

# Initial Organization Setup
LANGFUSE_INIT_ORG_ID=zuna-org
LANGFUSE_INIT_ORG_NAME=Zuna Organization

# Initial Project Setup
LANGFUSE_INIT_PROJECT_ID=zuna-project
LANGFUSE_INIT_PROJECT_NAME=Zuna Project
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=CHANGE_ME_LANGFUSE_PUBLIC_KEY
LANGFUSE_INIT_PROJECT_SECRET_KEY=CHANGE_ME_LANGFUSE_SECRET_KEY

# Initial User Setup
LANGFUSE_INIT_USER_EMAIL=admin@example.com
LANGFUSE_INIT_USER_NAME=Admin
LANGFUSE_INIT_USER_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# API Keys (For application integration - using init project keys)
LANGFUSE_PUBLIC_KEY=CHANGE_ME_LANGFUSE_PUBLIC_KEY
LANGFUSE_SECRET_KEY=CHANGE_ME_LANGFUSE_SECRET_KEY

# ============================================================================
# LiteLLM (LLM Gateway Proxy)
# ============================================================================
# Enable/Disable LiteLLM proxy (set to false to use direct provider SDKs)
# Default: true (use LiteLLM proxy for all LLM/embedding/rerank calls)
LITELLM_ENABLED=true

# Proxy Configuration
# IMPORTANT: Generate random keys for production (must start with sk-)
LITELLM_MASTER_KEY=CHANGE_ME_LITELLM_MASTER_KEY
LITELLM_SALT_KEY=CHANGE_ME_LITELLM_SALT_KEY

# UI Configuration
LITELLM_UI_USERNAME=admin
LITELLM_UI_PASSWORD=CHANGE_ME_LITELLM_UI_PASSWORD

# Model Names (when LiteLLM enabled - these are model IDs configured in LiteLLM)
LITELLM_CHAT_MODEL=gpt-4.1
LITELLM_EMBEDDING_MODEL=text-embedding-3-small
LITELLM_RERANK_MODEL=cohere-rerank-v3.5

# ============================================================================
# SQLPad (SQL Query Tool)
# ============================================================================
SQLPAD_ADMIN=admin@sqlpad.local
SQLPAD_ADMIN_PASSWORD=CHANGE_ME_SQLPAD_PASSWORD

# ============================================================================
# Azure OpenAI Configuration (Fallback when LiteLLM disabled)
# ============================================================================
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=CHANGE_ME_AZURE_OPENAI_API_KEY
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Azure OpenAI Deployment Names (when LiteLLM disabled - fallback models)
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# ============================================================================
# Azure AI Cohere Reranking Configuration
# ============================================================================
AZURE_AI_API_BASE=https://your-resource.eastus.models.ai.azure.com
AZURE_AI_API_KEY=CHANGE_ME_AZURE_AI_API_KEY

# ============================================================================
# Memory System (Mem0) Configuration
# ============================================================================
# Enable/Disable memory system (set to true to enable Mem0 integration)
# Default: false (memory system not yet integrated)
MEMORY_ENABLED=false

# ============================================================================
# Engine LLM Configuration
# ============================================================================
# LLM Temperature (0.0 = deterministic, 2.0 = very creative)
ENGINE_LLM_TEMPERATURE=0.7

# LLM Request Timeout (seconds)
ENGINE_LLM_TIMEOUT=60

# Enable/Disable Streaming Mode
ENGINE_LLM_STREAMING=false

# SSL Verification for HTTP Clients (set to false for local development with self-signed certs)
ENGINE_HTTP_SSL_VERIFY=false

# ============================================================================
# Agent Configuration (QnA Agent)
# ============================================================================
# Maximum messages before triggering conversation summarization
AGENT_MAX_MESSAGES_BEFORE_SUMMARY=10

# Number of messages to keep after summarization
AGENT_MESSAGES_TO_KEEP_AFTER_SUMMARY=2

# Number of recent messages to include in summary
AGENT_SUMMARY_MESSAGE_COUNT=5

# Maximum character length for summary content
AGENT_SUMMARY_MAX_LENGTH=200
